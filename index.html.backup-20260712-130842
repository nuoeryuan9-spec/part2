            <div class="layer folded-map map--two" data-depth="1.05" style="--base-x: 19vw; --base-y: 3vh; --base-z: 120px; --ry: -18deg; --rz: 8deg;"></div>
            <div class="layer text-slate slate--right" data-depth="1.18" style="--base-x: 2vw; --base-y: -16vh; --base-z: 230px; --rx: -4deg; --rz: 2deg;">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="layer character-placeholder character--cabinet" data-depth="1.38" style="--base-x: -7vw; --base-y: 24vh; --base-z: 310px;">
              <i class="head"></i>
              <i class="torso"></i>
              <i class="arm arm--left"></i>
              <i class="arm arm--right"></i>
              <i class="leg leg--left"></i>
              <i class="leg leg--right"></i>
            </div>
          </section>

          <section
            class="scene scene--horizon"
            data-point="0.94"
            style="--scene-x: 0px; --scene-y: -42px; --scene-z: -4660px; --scene-rx: 0deg; --scene-ry: 0deg; --scene-rz: 0deg;"
          >
            <div class="layer sun-disc sun-disc--low" data-depth="0.18" style="--base-x: 0px; --base-y: -24vh; --base-z: -560px;"></div>
            <div class="layer mountain mountain--final-a" data-depth="0.42" style="--base-x: -22vw; --base-y: 10vh; --base-z: -330px; --rz: -2deg;"></div>
            <div class="layer mountain mountain--final-b" data-depth="0.52" style="--base-x: 25vw; --base-y: 13vh; --base-z: -260px; --rz: 3deg;"></div>
            <div class="layer door-page door--left" data-depth="0.92" style="--base-x: -16vw; --base-y: 1vh; --base-z: 40px; --ry: 24deg; --rz: -3deg;"></div>
            <div class="layer door-page door--right" data-depth="0.92" style="--base-x: 16vw; --base-y: 1vh; --base-z: 42px; --ry: -24deg; --rz: 3deg;"></div>
            <div class="layer path-ribbon path-ribbon--final" data-depth="1.14" style="--base-x: 0px; --base-y: 31vh; --base-z: 180px; --rx: 72deg;"></div>
            <div class="layer character-placeholder character--final" data-depth="1.34" style="--base-x: 0px; --base-y: 20vh; --base-z: 330px;">
              <i class="head"></i>
              <i class="torso"></i>
              <i class="arm arm--left"></i>
              <i class="arm arm--right"></i>
              <i class="leg leg--left"></i>
              <i class="leg leg--right"></i>
